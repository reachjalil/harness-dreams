{
  "$schema": "https://turborepo.com/schema.json",
  "tasks": {
    "check": {
      "dependsOn": ["^check"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "src/**/*.ts",
        "src/**/*.tsx",
        "src/**/*.d.ts",
        "tsconfig.json"
      ],
      "outputs": [],
      "outputLogs": "new-only"
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
