{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "harnessdreams",
  "compatibility_date": "2026-06-27",
  "workers_dev": true,
  "assets": {
    "directory": "./dist",
    "html_handling": "auto-trailing-slash",
    "not_found_handling": "404-page"
  },
  "observability": {
    "enabled": true
  },
  "routes": [
    { "pattern": "harnessdreams.com", "custom_domain": true },
    { "pattern": "www.harnessdreams.com", "custom_domain": true }
  ]
}
