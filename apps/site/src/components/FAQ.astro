---
const faqs = [
  {
    q: "Which harnesses does it support?",
    a: "Claude Code first — it keeps a rich, local telemetry trail we can read directly. Codex and Cursor connectors follow. Everything normalizes into one model, so cross-tool comparisons work as soon as you connect a second harness.",
  },
  {
    q: "Does my code leave my machine?",
    a: "Not by default. Ingestion, storage, and your core metrics are fully local and work offline. Deeper model-powered analysis is opt-in and only ever sees small, secret-scrubbed excerpts — never whole transcripts. A no-cloud mode is a first-class option.",
  },
  {
    q: "How does it actually change my harness's behavior?",
    a: "Through the safest levers first: reversible, clearly-marked edits to your AGENTS.md and memory, plus gentle nudges you opt into. Every change is shown as a diff you approve, with a backup and one-click undo. Nothing is ever applied silently.",
  },
  {
    q: "Is this just another dashboard I'll ignore?",
    a: "It's built to be the opposite. The morning report is a ~90-second ritual with a few high-confidence findings — not a wall of charts. Quiet nights are allowed: if nothing notable happened, it says so instead of inventing insight.",
  },
  {
    q: "What will it cost?",
    a: "Pricing isn't set yet — it's in active development. By design, the heavy lifting (your vitals and trends) is computed locally and free; only optional deep analysis uses a model, under a budget you control.",
  },
  {
    q: "What platform does it run on?",
    a: "A native macOS menu-bar app — it lives in your top toolbar, runs quietly in the background, and surfaces your report each morning. Other platforms may come later.",
  },
];
---

<section class="section" id="faq">
  <div class="container">
    <div class="head section-narrow reveal">
      <span class="eyebrow">Questions</span>
      <h2 class="h2">Good questions, honest answers.</h2>
    </div>

    <div class="faq-list section-narrow">
      {
        faqs.map((f, i) => (
          <details class="faq reveal" data-delay={((i % 3) + 1).toString()}>
            <summary>
              <span>{f.q}</span>
              <span class="chev" aria-hidden="true">+</span>
            </summary>
            <p>{f.a}</p>
          </details>
        ))
      }
    </div>
  </div>
</section>

<style>
  .head {
    display: grid;
    gap: 1rem;
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }
  .faq-list {
    display: grid;
    gap: 0.7rem;
  }
  .faq {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--surface);
    overflow: hidden;
  }
  summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.1rem 1.3rem;
    cursor: pointer;
    font-weight: 600;
    font-size: 1.02rem;
    letter-spacing: -0.01em;
    list-style: none;
  }
  summary::-webkit-details-marker {
    display: none;
  }
  summary:focus-visible {
    outline: 3px solid rgba(74, 108, 247, 0.4);
    outline-offset: -3px;
    border-radius: var(--radius);
  }
  .chev {
    flex: none;
    width: 26px;
    height: 26px;
    display: grid;
    place-items: center;
    border-radius: 7px;
    background: rgba(74, 108, 247, 0.1);
    color: var(--accent);
    font-size: 1.1rem;
    line-height: 1;
    transition: transform 0.2s ease;
  }
  .faq[open] .chev {
    transform: rotate(45deg);
  }
  .faq p {
    padding: 0 1.3rem 1.2rem;
    color: var(--muted);
    font-size: 0.97rem;
    line-height: 1.55;
    max-width: 70ch;
  }
</style>
