---
const repoUrl = "https://github.com/reachjalil/harness-dreams";
const links = [
  { href: "/start/", label: "Download" },
  { href: "/cycle/", label: "Cycle" },
  { href: "/case-studies/", label: "Case studies" },
  { href: "/docs/", label: "Docs" },
  { href: "/blog/", label: "Blog" },
  { href: "/#privacy", label: "Privacy" },
];
---

<header class="nav">
  <div class="container nav-inner">
    <a class="brand" href="/" aria-label="Harness Dreams home">
      <span class="logo" aria-hidden="true">
        <img src="/logo.png" alt="" width="34" height="34" />
      </span>
      <span class="brand-name">Harness Dreams</span>
    </a>

    <nav class="nav-links" aria-label="Primary">
      {links.map((l) => <a href={l.href}>{l.label}</a>)}
    </nav>

    <div class="nav-cta">
      <a class="ghost" href={repoUrl} target="_blank" rel="noreferrer noopener"
        >GitHub</a
      >
      <a class="btn btn-primary nav-btn" href="/start/">Download for macOS</a>
    </div>
  </div>
</header>

<style>
  .nav {
    position: fixed;
    top: 0;
    inset-inline: 0;
    z-index: 80;
    padding-block: clamp(0.65rem, 1.4vw, 0.95rem);
    pointer-events: none;
  }
  .nav-inner {
    width: min(calc(100% - 1.5rem), 88rem);
    height: 3.45rem;
    display: flex;
    align-items: center;
    gap: clamp(0.85rem, 2vw, 1.35rem);
    padding: 0.35rem 0.45rem 0.35rem 0.75rem;
    border: 1px solid rgba(255, 255, 255, 0.42);
    border-radius: 999px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.82), rgba(255, 255, 255, 0.68)),
      rgba(255, 255, 255, 0.72);
    box-shadow: 0 20px 60px -36px rgba(11, 18, 28, 0.45);
    backdrop-filter: blur(24px) saturate(145%);
    -webkit-backdrop-filter: blur(24px) saturate(145%);
    pointer-events: auto;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--ink);
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.12rem;
    letter-spacing: 0;
  }
  .logo {
    display: grid;
    place-items: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 999px;
    overflow: hidden;
    background: var(--surface);
    border: 1px solid var(--line);
  }
  .logo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .nav-links {
    display: none;
    gap: clamp(0.9rem, 1.7vw, 1.35rem);
    margin-inline: auto;
  }
  .nav-links a {
    color: var(--muted);
    font-size: 0.92rem;
    font-weight: 500;
    transition: color 0.15s ease;
  }
  .nav-links a:hover {
    color: var(--ink);
  }
  .nav-cta {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    margin-left: auto;
  }
  .ghost {
    color: var(--muted);
    font-size: 0.92rem;
    font-weight: 550;
  }
  .ghost:hover {
    color: var(--ink);
  }
  .nav-btn {
    padding: 0.62rem 1.05rem;
    font-size: 0.9rem;
    background: var(--night);
    color: #fff;
    box-shadow: none;
  }

  .nav-btn:hover {
    border-color: transparent;
    background: #172335;
    color: #fff;
    box-shadow: 0 14px 30px -20px rgba(11, 18, 28, 0.6);
  }

  @media (min-width: 880px) {
    .nav-links {
      display: flex;
    }
    .nav-cta {
      margin-left: 0;
    }
  }
  @media (max-width: 520px) {
    .brand-name {
      display: none;
    }

    .ghost {
      display: none;
    }
  }
</style>
