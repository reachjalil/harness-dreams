---
/**
 * Desktop-matched concentric activity rings.
 * Three composite scores: Efficiency, Effectiveness, Alignment (0-100).
 */
interface Props {
  efficiency: number;
  effectiveness: number;
  alignment: number;
  size?: number;
  className?: string;
  track?: string;
  colors?: string[];
}

const {
  efficiency,
  effectiveness,
  alignment,
  size = 188,
  className = "",
  track,
  colors,
} = Astro.props as Props;

const rings = [
  { key: "efficiency", score: efficiency },
  { key: "effectiveness", score: effectiveness },
  { key: "alignment", score: alignment },
];
const center = size / 2;
const stroke = 13;
const gap = 6;
---

<svg
  class={`rings desktop-rings ${className}`}
  width={size}
  height={size}
  viewBox={`0 0 ${size} ${size}`}
  role="img"
  aria-label={`Efficiency ${efficiency}, Effectiveness ${effectiveness}, Alignment ${alignment} out of 100`}
>
  {
    rings.map((ring, i) => {
      const radius = center - stroke / 2 - i * (stroke + gap);
      const score = Math.max(0, Math.min(100, ring.score));
      const color = colors?.[i];
      return (
        <g transform={`rotate(-90 ${center} ${center})`}>
          <circle
            class="ring-track"
            cx={center}
            cy={center}
            r={radius}
            stroke-width={stroke}
            fill="none"
            style={track ? `stroke:${track}` : undefined}
          />
          <circle
            class={`ring-arc ${ring.key}`}
            cx={center}
            cy={center}
            r={radius}
            stroke-width={stroke}
            fill="none"
            pathLength="100"
            stroke-dasharray={`${score} 100`}
            stroke-linecap="round"
            style={color ? `stroke:${color}` : undefined}
          />
        </g>
      );
    })
  }
</svg>
