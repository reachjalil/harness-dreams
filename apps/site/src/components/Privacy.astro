---
const guarantees = [
  {
    title: "Local-first by default",
    body: "Ingestion, storage, and your core metrics run entirely on-device. The app works offline.",
  },
  {
    title: "Cloud is opt-in and redacted",
    body: "Deeper analysis with a model is your choice — and only ever sees small, secret-scrubbed excerpts, never whole transcripts.",
  },
  {
    title: "Secrets never leave. Ever.",
    body: "API keys, .env files, and credentials are scanned out before anything is sent, and never written to your config.",
  },
  {
    title: "Nothing changes without consent",
    body: "Every edit to your AGENTS.md, skills, or memory is shown as a diff you approve — with a backup and one-click undo.",
  },
];
---

<section class="section" id="privacy">
  <div class="container">
    <div class="privacy card reveal">
      <div class="p-copy">
        <span class="eyebrow">Privacy &amp; trust</span>
        <h2 class="h2">Your code never leaves your machine.</h2>
        <p class="lead">
          Harness Dreams reads the most sensitive thing you have — full
          transcripts of your work. So privacy isn't a feature here. It's the
          whole license to operate.
        </p>
        <a class="btn" href="/start/">Download for macOS</a>
      </div>

      <ul class="g-list">
        {
          guarantees.map((g, i) => (
            <li class="reveal" data-delay={((i % 3) + 1).toString()}>
              <span class="lock" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="5" y="11" width="14" height="9" rx="2" />
                  <path d="M8 11V8a4 4 0 0 1 8 0v3" />
                </svg>
              </span>
              <div>
                <h3>{g.title}</h3>
                <p>{g.body}</p>
              </div>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>

<style>
  .privacy {
    padding: clamp(1.75rem, 4vw, 2.75rem);
    display: grid;
    gap: clamp(2rem, 4vw, 3rem);
    background:
      radial-gradient(70% 90% at 0% 0%, rgba(58, 171, 156, 0.08), transparent 55%),
      linear-gradient(180deg, var(--surface), rgba(255, 255, 255, 0));
  }
  .p-copy {
    display: grid;
    gap: 1.1rem;
    justify-items: start;
    align-content: start;
  }
  .g-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1.1rem;
  }
  .g-list li {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.85rem;
    align-items: start;
  }
  .lock {
    display: grid;
    place-items: center;
    width: 32px;
    height: 32px;
    border-radius: 9px;
    background: rgba(58, 171, 156, 0.12);
    border: 1px solid var(--line);
    color: var(--good);
    flex: none;
  }
  .g-list h3 {
    font-size: 1rem;
    font-weight: 640;
    margin-bottom: 0.2rem;
  }
  .g-list p {
    color: var(--muted);
    font-size: 0.93rem;
  }
  @media (min-width: 880px) {
    .privacy {
      grid-template-columns: 0.9fr 1.1fr;
    }
    .g-list {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
