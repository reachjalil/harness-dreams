---
/**
 * Interactive hero demo — the Harness Dreams app in its "night" treatment.
 * Shows a summary on load (rings + scores animate in); pressing "Dream now"
 * plays the staged dream sequence, then reveals a fresh report. Sample data,
 * 100% client-side. Degrades to a static summary without JS.
 */
const rings = [
  {
    key: "efficiency",
    label: "Efficiency",
    hint: "Tokens & cost / change",
    color: "#4a6cf7",
    score: 78,
    delta: 6,
  },
  {
    key: "effectiveness",
    label: "Effectiveness",
    hint: "Less back-and-forth",
    color: "#a7dad3",
    score: 64,
    delta: -3,
  },
  {
    key: "alignment",
    label: "Alignment",
    hint: "Fewer corrections",
    color: "#f0b07a",
    score: 83,
    delta: 2,
  },
];
const composite = Math.round(
  rings.reduce((a, r) => a + r.score, 0) / rings.length
);
const radii = [61, 48, 35];
const stages = [
  "Replaying the day's sessions",
  "Computing vitals · deep sleep",
  "Finding patterns · REM",
  "Drafting findings & improvements",
  "Assembling your report",
];
---

<div class="demo" data-demo>
  <div class="appwin">
    <div class="titlebar">
      <span class="lights" aria-hidden="true">
        <i style="background:#ff5f57"></i>
        <i style="background:#febc2e"></i>
        <i style="background:#28c840"></i>
      </span>
      <span class="brandchip" aria-hidden="true">
        <img src="/logo.png" alt="" width="20" height="20" />
      </span>
      <span class="win-title mono">Harness Dreams</span>
      <span class="live-pill mono"><i></i>Live</span>
    </div>

    <div class="body">
      {/* ── Report ─────────────────────────────── */}
      <div class="view" data-view="report">
        <div class="row-head">
          <div>
            <div class="ser date">Last night · 14 sessions</div>
            <div class="meta">Claude Code · 5 projects</div>
          </div>
          <button class="mini primary" type="button" data-dream>Dream now</button>
        </div>

        <div class="t-grid">
          <div class="ring">
            <svg viewBox="0 0 132 132" aria-hidden="true">
              <g
                transform="rotate(-90 66 66)"
                fill="none"
                stroke-width="10"
                stroke-linecap="round"
              >
                {
                  rings.map((r, i) => (
                    <>
                      <circle
                        cx="66"
                        cy="66"
                        r={radii[i]}
                        stroke="rgba(255,255,255,0.08)"
                      />
                      <circle
                        class="arc"
                        data-ring={r.key}
                        data-val={r.score}
                        cx="66"
                        cy="66"
                        r={radii[i]}
                        stroke={r.color}
                        pathLength="100"
                        stroke-dasharray="100"
                        stroke-dashoffset={100 - r.score}
                      />
                    </>
                  ))
                }
              </g>
            </svg>
            <div class="ring-c">
              <div class="ser num" data-composite={composite}>{composite}</div>
              <div class="cap">Dream score</div>
            </div>
          </div>

          <div class="contribs">
            {
              rings.map((r) => (
                <div class="c">
                  <div class="c-top">
                    <span>{r.label}</span>
                    <b class="ser" data-cscore={r.key}>
                      {r.score}
                    </b>
                  </div>
                  <div class="bar">
                    <i
                      data-cbar={r.key}
                      style={`width:${r.score}%;background:${r.color}`}
                    />
                  </div>
                  <div class="c-foot">
                    <span>{r.hint}</span>
                    <em
                      class={`c-delta ${r.delta >= 0 ? "up" : "dn"}`}
                      data-cdelta={r.key}
                      data-delta={r.delta}
                    >
                      {r.delta >= 0 ? "+" : ""}
                      {r.delta}
                    </em>
                  </div>
                </div>
              ))
            }
          </div>
        </div>

        <p class="digest" data-digest>
          Solid day. Tokens-per-change dropped <b>12%</b> vs your two-week
          median, mostly in <span class="repo">agent-fleet</span>.
        </p>
      </div>

      {/* ── Dreaming ───────────────────────────── */}
      <div class="view" data-view="dreaming" hidden>
        <div class="eyebrow">Dreaming</div>
        <div class="orb"><span class="ser" data-pct>0%</span></div>
        <div class="d-bar"><i data-bar></i></div>
        <ul class="stages">
          {stages.map((s) => <li class="stage" data-stage><i />{s}</li>)}
        </ul>
      </div>
    </div>
  </div>

  <p class="cap-foot">Live demo — press <b>Dream now</b> · sample data</p>
</div>

<style>
  .demo {
    --bg: #0d1b2a;
    --panel-2: #102032;
    --txt: #f4f6f8;
    --mut: #9fb0c4;
    --fnt: #6b7888;
    --acc: #4a6cf7;
    --vio: #a78bfa;
    --good: #5bb5a6;
    --warn: #f0b07a;
    --line: rgba(255, 255, 255, 0.08);
    --line-2: rgba(255, 255, 255, 0.16);
    width: min(100%, 25rem);
    margin-inline: auto;
    display: grid;
    gap: 0.65rem;
    font-size: 13px;
  }
  .appwin {
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid var(--line-2);
    background:
      radial-gradient(
        900px 420px at 50% -18%,
        rgba(167, 139, 250, 0.32) 0%,
        rgba(74, 108, 247, 0.16) 34%,
        rgba(13, 27, 42, 0.9) 62%
      ),
      var(--bg);
    color: var(--txt);
    box-shadow:
      0 40px 80px -30px rgba(13, 27, 42, 0.55),
      0 0 60px -20px rgba(167, 139, 250, 0.45);
  }
  .titlebar {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.55rem 0.75rem;
    border-bottom: 1px solid var(--line);
  }
  .lights {
    display: inline-flex;
    gap: 6px;
  }
  .lights i {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    display: block;
  }
  .brandchip {
    width: 22px;
    height: 22px;
    border-radius: 6px;
    overflow: hidden;
    background: #f6f6f6;
    display: grid;
    place-items: center;
    margin-left: 0.2rem;
  }
  .brandchip img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .win-title {
    color: var(--mut);
    font-size: 0.66rem;
    margin-inline: auto;
  }
  .live-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    color: var(--good);
    border: 1px solid rgba(91, 181, 166, 0.4);
    border-radius: 999px;
    padding: 0.13rem 0.5rem;
    font-size: 0.6rem;
  }
  .live-pill i {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--good);
    animation: blink 1.8s ease-in-out infinite;
  }

  .body {
    position: relative;
    min-height: 19.5rem;
    padding: 0.85rem 1rem 1rem;
  }
  .view {
    display: grid;
    gap: 0.8rem;
    align-content: start;
    animation: fade 0.4s ease both;
  }
  .view[hidden] {
    display: none;
  }

  .ser {
    font-family: var(--font-display);
  }
  .row-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.6rem;
  }
  .date {
    font-size: 1.02rem;
  }
  .meta {
    color: var(--mut);
    font-size: 0.8rem;
    margin-top: 0.1rem;
  }

  .t-grid {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1rem;
    align-items: center;
  }
  .ring {
    position: relative;
    width: 132px;
    height: 132px;
    filter: drop-shadow(0 0 18px rgba(167, 139, 250, 0.25));
  }
  .ring svg {
    width: 132px;
    height: 132px;
  }
  .arc {
    transition: stroke-dashoffset 1.1s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .ring-c {
    position: absolute;
    inset: 0;
    display: grid;
    place-content: center;
    text-align: center;
  }
  .num {
    font-size: 2.4rem;
    line-height: 1;
  }
  .cap {
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--fnt);
    margin-top: 0.2rem;
  }
  .contribs {
    display: grid;
    gap: 0.7rem;
  }
  .c-top {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    font-size: 0.84rem;
  }
  .c-top b {
    font-size: 1rem;
  }
  .bar {
    margin-top: 0.3rem;
    height: 6px;
    border-radius: 99px;
    background: var(--panel-2);
    overflow: hidden;
  }
  .bar i {
    display: block;
    height: 100%;
    border-radius: 99px;
    transition: width 1s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .c-foot {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-top: 0.28rem;
    font-size: 0.72rem;
    color: var(--fnt);
  }
  .c-delta {
    font-style: normal;
  }
  .up {
    color: var(--good);
  }
  .dn {
    color: var(--warn);
  }

  .digest {
    color: var(--mut);
    font-size: 0.85rem;
    line-height: 1.5;
  }
  .digest b {
    color: var(--txt);
  }
  .repo {
    font-family: var(--font-mono);
    font-size: 0.82em;
    color: var(--vio);
  }

  .eyebrow {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--vio);
  }
  .orb {
    height: 120px;
    display: grid;
    place-items: center;
    position: relative;
    margin-top: 0.2rem;
  }
  .orb::before {
    content: "";
    position: absolute;
    width: 112px;
    height: 112px;
    border-radius: 50%;
    background: radial-gradient(
      circle at 50% 45%,
      var(--vio) 0%,
      #7c5cfc 55%,
      rgba(124, 92, 252, 0) 72%
    );
    animation: breathe 3s ease-in-out infinite;
  }
  .orb span {
    position: relative;
    font-size: 1.8rem;
  }
  .d-bar {
    height: 7px;
    border-radius: 99px;
    background: var(--panel-2);
    overflow: hidden;
  }
  .d-bar i {
    display: block;
    height: 100%;
    width: 0%;
    border-radius: 99px;
    background: linear-gradient(90deg, var(--vio), var(--acc));
  }
  .stages {
    list-style: none;
    margin: 0.2rem 0 0;
    padding: 0;
    display: grid;
    gap: 0.5rem;
  }
  .stages li {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.84rem;
    color: var(--fnt);
  }
  .stages li i {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--line-2);
    flex: none;
  }
  .stages li.done {
    color: var(--mut);
  }
  .stages li.done i {
    background: var(--good);
  }
  .stages li.act {
    color: var(--txt);
  }
  .stages li.act i {
    background: var(--vio);
    box-shadow: 0 0 0 4px rgba(167, 139, 250, 0.2);
  }

  .mini {
    display: inline-block;
    padding: 0.34rem 0.75rem;
    border-radius: 7px;
    border: 1px solid var(--line-2);
    background: transparent;
    color: var(--txt);
    font: inherit;
    font-size: 0.78rem;
    font-weight: 550;
    cursor: pointer;
  }
  .mini.primary {
    background: var(--acc);
    border-color: transparent;
    color: #fff;
  }
  .mini:disabled {
    opacity: 0.55;
    cursor: default;
  }

  .cap-foot {
    text-align: center;
    color: var(--faint);
    font-size: 0.78rem;
  }
  .cap-foot b {
    color: var(--muted);
  }

  @keyframes blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.3;
    }
  }
  @keyframes breathe {
    0%,
    100% {
      opacity: 0.8;
    }
    50% {
      opacity: 1;
    }
  }
  @keyframes fade {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .arc,
    .bar i {
      transition: none;
    }
    .orb::before,
    .live-pill i,
    .view {
      animation: none;
    }
  }
</style>

<script>
  const KEYS = ["efficiency", "effectiveness", "alignment"];
  const DIGESTS = [
    'Solid day. Tokens-per-change dropped <b>12%</b> vs your two-week median, mostly in <span class="repo">agent-fleet</span>.',
    'Quietly efficient — cache hits climbed and you shipped more with fewer follow-ups in <span class="repo">applied-intelligence</span>.',
    "Strong alignment: almost no reverts. Token spend crept up on a couple of long debugging sessions.",
    "Good momentum — the verify skill kept regressions out and UI work needed less back-and-forth.",
  ];
  const STAGE_AT = [0, 0.16, 0.36, 0.58, 0.8];

  function rnd(a: number, b: number): number {
    return Math.round(a + Math.random() * (b - a));
  }

  for (const root of document.querySelectorAll<HTMLElement>("[data-demo]")) {
    const reduce = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;
    const q = <T extends Element>(sel: string): T | null =>
      root.querySelector<T>(sel);
    const reportView = q<HTMLElement>('[data-view="report"]');
    const dreamView = q<HTMLElement>('[data-view="dreaming"]');
    const composeEl = q<HTMLElement>("[data-composite]");
    const digestEl = q<HTMLElement>("[data-digest]");
    const dreamBtn = q<HTMLButtonElement>("[data-dream]");
    const pctEl = q<HTMLElement>("[data-pct]");
    const barEl = q<HTMLElement>("[data-bar]");
    const stageEls = [...root.querySelectorAll<HTMLElement>("[data-stage]")];
    if (!reportView || !dreamView || !composeEl || !dreamBtn) continue;

    const countUp = (el: HTMLElement | null, to: number): void => {
      if (!el) return;
      if (reduce) {
        el.textContent = String(to);
        return;
      }
      const from = Number(el.textContent) || 0;
      const start = performance.now();
      const tick = (t: number): void => {
        const p = Math.min(1, (t - start) / 900);
        const e = 1 - (1 - p) ** 3;
        el.textContent = String(Math.round(from + (to - from) * e));
        if (p < 1) requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);
    };

    type Ring = { key: string; score: number; delta: number };
    const apply = (
      report: { rings: Ring[]; composite: number; digest: string },
      sweep: boolean,
    ): void => {
      if (digestEl) digestEl.innerHTML = report.digest;
      countUp(composeEl, report.composite);
      for (const r of report.rings) {
        const arc = q<SVGCircleElement>(`[data-ring="${r.key}"]`);
        if (arc) {
          arc.dataset.val = String(r.score);
          const target = 100 - r.score;
          if (sweep && !reduce) {
            arc.style.strokeDashoffset = "100";
            void arc.getBoundingClientRect();
            requestAnimationFrame(() => {
              arc.style.strokeDashoffset = String(target);
            });
          } else {
            arc.style.strokeDashoffset = String(target);
          }
        }
        countUp(q<HTMLElement>(`[data-cscore="${r.key}"]`), r.score);
        const bar = q<HTMLElement>(`[data-cbar="${r.key}"]`);
        if (bar) {
          if (sweep && !reduce) {
            bar.style.width = "0%";
            void bar.getBoundingClientRect();
            requestAnimationFrame(() => {
              bar.style.width = `${r.score}%`;
            });
          } else {
            bar.style.width = `${r.score}%`;
          }
        }
        const delta = q<HTMLElement>(`[data-cdelta="${r.key}"]`);
        if (delta) {
          delta.dataset.delta = String(r.delta);
          delta.textContent = `${r.delta >= 0 ? "+" : ""}${r.delta}`;
          delta.className = `c-delta ${r.delta >= 0 ? "up" : "dn"}`;
        }
      }
    };

    const makeReport = (): { rings: Ring[]; composite: number; digest: string } => {
      const ranges: Record<string, [number, number, number, number]> = {
        efficiency: [66, 90, -3, 9],
        effectiveness: [56, 80, -6, 6],
        alignment: [74, 92, -2, 7],
      };
      const r = KEYS.map((key) => {
        const [lo, hi, dlo, dhi] = ranges[key];
        return { key, score: rnd(lo, hi), delta: rnd(dlo, dhi) };
      });
      return {
        rings: r,
        composite: Math.round(r.reduce((a, x) => a + x.score, 0) / r.length),
        digest: DIGESTS[rnd(0, DIGESTS.length - 1)],
      };
    };

    let running = false;
    const startDream = (): void => {
      if (running) return;
      running = true;
      dreamBtn.disabled = true;
      const next = makeReport();
      reportView.hidden = true;
      dreamView.hidden = false;
      for (const s of stageEls) s.className = "stage";
      const dur = reduce ? 300 : 4600;
      const start = performance.now();
      const step = (t: number): void => {
        const p = Math.min(1, (t - start) / dur);
        if (pctEl) pctEl.textContent = `${Math.round(p * 100)}%`;
        if (barEl) barEl.style.width = `${p * 100}%`;
        stageEls.forEach((s, i) => {
          const nextAt = STAGE_AT[i + 1] ?? 1;
          s.className = `stage ${p >= nextAt ? "done" : p >= STAGE_AT[i] ? "act" : ""}`;
        });
        if (p < 1) {
          requestAnimationFrame(step);
        } else {
          dreamView.hidden = true;
          reportView.hidden = false;
          apply(next, true);
          running = false;
          dreamBtn.disabled = false;
        }
      };
      requestAnimationFrame(step);
    };
    dreamBtn.addEventListener("click", startDream);

    // Animate the initial summary in on load.
    const initial = {
      rings: KEYS.map((key) => {
        const arc = q<SVGCircleElement>(`[data-ring="${key}"]`);
        const delta = q<HTMLElement>(`[data-cdelta="${key}"]`);
        return {
          key,
          score: Number(arc?.dataset.val) || 0,
          delta: Number(delta?.dataset.delta) || 0,
        };
      }),
      composite: Number(composeEl.dataset.composite) || 0,
      digest: digestEl ? digestEl.innerHTML : "",
    };
    composeEl.textContent = "0";
    for (const key of KEYS) {
      const cs = q<HTMLElement>(`[data-cscore="${key}"]`);
      if (cs) cs.textContent = "0";
    }
    apply(initial, true);
  }
</script>
