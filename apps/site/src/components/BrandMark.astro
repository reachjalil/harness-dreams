---
/**
 * "Quiet Orbit" brand mark — a crescent moon with an orbiting planet.
 * Crescent subtly reads as an H for Harness. Reusable at any size/color.
 */
interface Props {
  size?: number;
  moon?: string;
  orbit?: string;
  planet?: string;
}
const {
  size = 28,
  moon = "var(--ink)",
  orbit = "var(--teal-deep)",
  planet = "var(--teal-deep)",
} = Astro.props as Props;

// Unique mask id so multiple marks on one page don't collide.
const uid = `bm-${Math.random().toString(36).slice(2, 8)}`;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 32 32"
  fill="none"
  role="img"
  aria-label="Harness Dreams"
>
  <mask id={uid}>
    <rect width="32" height="32" fill="white"></rect>
    <circle cx="21.5" cy="13" r="10.5" fill="black"></circle>
  </mask>
  <ellipse
    cx="16"
    cy="18.5"
    rx="15"
    ry="5.6"
    transform="rotate(-20 16 18.5)"
    fill="none"
    stroke={orbit}
    stroke-width="1.4"
    opacity="0.85"></ellipse>
  <circle cx="15" cy="16" r="11" fill={moon} mask={`url(#${uid})`}></circle>
  <circle cx="28.4" cy="11.7" r="2.1" fill={planet}></circle>
</svg>
