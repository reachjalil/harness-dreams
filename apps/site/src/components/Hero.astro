---
---

<section class="hero splash-hero" id="top">
  <div class="splash-motion" aria-hidden="true">
    <span class="splash-shape shape-a"></span>
    <span class="splash-shape shape-b"></span>
    <span class="splash-shape shape-c"></span>
  </div>

  <div class="splash-content">
    <div class="splash-icon-loop" aria-hidden="true">
      <!-- review — Harness Health mark -->
      <span class="splash-icon icon-logo">
        <img src="/logo-white.png" alt="" loading="eager" decoding="async" />
      </span>

      <span class="splash-icon icon-review">
        <img src="/splash-icons/review.png" alt="" loading="eager" decoding="async" />
      </span>

      <span class="splash-icon icon-connect">
        <img src="/splash-icons/connect.png" alt="" loading="eager" decoding="async" />
      </span>

      <span class="splash-icon icon-adapt">
        <img src="/splash-icons/adapt.png" alt="" loading="eager" decoding="async" />
      </span>

      <span class="splash-icon icon-improve">
        <img src="/splash-icons/improve.png" alt="" loading="eager" decoding="async" />
      </span>
    </div>

    <p class="splash-product">Harness Health</p>
    <h1>How healthy is your AI coding harness?</h1>
    <p
      class="splash-answer"
      aria-label="It should review, reflect, connect, adapt, and improve."
    >
      <span aria-hidden="true">It should&nbsp;</span>
      <span class="answer-morph" aria-hidden="true">
        <span class="answer-sizer">improve.</span>
        <span class="answer-word aw-1">review.</span>
        <span class="answer-word aw-2">reflect.</span>
        <span class="answer-word aw-3">connect.</span>
        <span class="answer-word aw-4">adapt.</span>
        <span class="answer-word aw-5">improve.</span>
      </span>
    </p>
    <p class="splash-lede">
      A health app for the coding harness you work inside. While you're away it
      reviews the day's sessions, finds what to fix, and wakes you with a short,
      reviewable list of changes for tomorrow.
    </p>

    <div class="hero-cta">
      <a class="btn btn-primary hero-primary" href="/start/">Download for macOS</a>
      <a class="btn hero-secondary" href="#insights">Learn more</a>
    </div>

    <a class="sync-teaser" href="#cloud-sync" aria-label="Learn about Private Device Sync for iPhone and Apple Watch">
      <span class="device-stack" aria-hidden="true">
        <span class="device-phone"></span>
        <span class="device-watch"></span>
      </span>
      <span>
        Private companion:
        <strong>iPhone &amp; Apple Watch</strong>
        with 2-week trial
      </span>
    </a>
  </div>

  <a class="scroll-cue" href="#insights" aria-label="Scroll to more insights">
    <span></span>
  </a>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: grid;
    place-items: center;
    overflow: hidden;
    isolation: isolate;
    background:
      linear-gradient(180deg, rgba(0, 0, 0, 0.05), transparent 42%),
      linear-gradient(150deg, #084c9a 0%, #0c82c2 100%);
    color: #fff;
    padding: clamp(4.5rem, 8vw, 7rem) clamp(1.25rem, 4vw, 2rem);
  }

  .hero::before,
  .hero::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 0;
    opacity: 0;
    pointer-events: none;
  }

  .hero::before {
    background: linear-gradient(150deg, #075f57 0%, #169f91 100%);
    animation: gradient-teal 20s linear infinite;
  }

  .hero::after {
    background: linear-gradient(150deg, #302e87 0%, #655fd0 100%);
    animation: gradient-violet 20s linear infinite;
  }

  .splash-motion {
    position: absolute;
    inset: 0;
    z-index: 1;
    overflow: hidden;
  }

  .splash-shape {
    position: absolute;
    display: block;
    left: -18vw;
    width: 136vw;
    height: clamp(15rem, 31vw, 28rem);
    opacity: 0.52;
    transform-origin: 50% 50%;
    filter: blur(7px);
    mix-blend-mode: screen;
    will-change: transform, opacity, border-radius;
  }

  .shape-a {
    top: 4vh;
    border-radius: 43% 57% 61% 39% / 58% 42% 58% 42%;
    background:
      radial-gradient(ellipse at 18% 50%, rgba(255, 255, 255, 0.24), transparent 38%),
      radial-gradient(ellipse at 62% 45%, rgba(169, 224, 255, 0.2), transparent 42%),
      linear-gradient(92deg, transparent 0%, rgba(255, 255, 255, 0.15) 22%, rgba(255, 255, 255, 0.06) 68%, transparent 100%);
    animation: wave-layer-a 20s linear infinite;
  }

  .shape-b {
    top: 25vh;
    border-radius: 55% 45% 48% 52% / 43% 57% 43% 57%;
    background:
      radial-gradient(ellipse at 30% 48%, rgba(196, 179, 255, 0.2), transparent 40%),
      radial-gradient(ellipse at 76% 52%, rgba(255, 255, 255, 0.17), transparent 38%),
      linear-gradient(96deg, transparent 0%, rgba(255, 255, 255, 0.11) 20%, rgba(169, 224, 255, 0.12) 58%, transparent 100%);
    opacity: 0.46;
    animation: wave-layer-b 20s linear infinite;
  }

  .shape-c {
    top: 47vh;
    border-radius: 49% 51% 54% 46% / 65% 35% 65% 35%;
    background:
      radial-gradient(ellipse at 24% 54%, rgba(255, 255, 255, 0.18), transparent 36%),
      radial-gradient(ellipse at 70% 46%, rgba(157, 180, 255, 0.18), transparent 40%),
      linear-gradient(88deg, transparent 0%, rgba(255, 255, 255, 0.1) 28%, rgba(255, 255, 255, 0.15) 58%, transparent 100%);
    opacity: 0.44;
    animation: wave-layer-c 20s linear infinite;
  }

  .splash-content {
    position: relative;
    z-index: 2;
    width: min(100%, 68rem);
    display: grid;
    justify-items: center;
    gap: 0.85rem;
    text-align: center;
  }

  .splash-icon-loop {
    position: relative;
    width: 5.4rem;
    height: 5.4rem;
    margin-bottom: 0.35rem;
  }

  .splash-icon-loop::before,
  .splash-icon-loop::after {
    content: "";
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
  }

  .splash-icon-loop::before {
    inset: -0.4rem;
    background: conic-gradient(
      from 30deg,
      rgba(255, 255, 255, 0.03),
      rgba(255, 255, 255, 0.28),
      rgba(255, 255, 255, 0.02) 34%,
      transparent 56%,
      rgba(255, 255, 255, 0.18) 72%,
      rgba(255, 255, 255, 0.03)
    );
    -webkit-mask: radial-gradient(farthest-side, transparent calc(100% - 1px), #000 0);
    mask: radial-gradient(farthest-side, transparent calc(100% - 1px), #000 0);
    animation: icon-orbit 20s linear infinite;
  }

  .splash-icon-loop::after {
    inset: 0.34rem;
    background: conic-gradient(
      from -70deg,
      transparent,
      rgba(255, 255, 255, 0.18),
      transparent 42%,
      rgba(255, 255, 255, 0.11) 58%,
      transparent
    );
    -webkit-mask: radial-gradient(farthest-side, transparent calc(100% - 1px), #000 0);
    mask: radial-gradient(farthest-side, transparent calc(100% - 1px), #000 0);
    animation: icon-orbit 28s linear infinite reverse;
  }

  .splash-icon {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    opacity: 0;
    transform: translateY(14px) rotate(-10deg) scale(0.84);
    animation: icon-loop 20s linear infinite;
  }

  .splash-icon img {
    width: 94%;
    height: 94%;
    object-fit: contain;
  }

  /* Each phase runs on a shared 20s timeline: logo first, then enhancement icons. */
  .icon-logo {
    animation-delay: 0s;
  }
  .icon-review {
    animation-delay: 4s;
  }
  .icon-connect {
    animation-delay: 8s;
  }
  .icon-adapt {
    animation-delay: 12s;
  }
  .icon-improve {
    animation-delay: 16s;
  }

  .splash-product {
    color: rgba(255, 255, 255, 0.78);
    font-size: clamp(1rem, 1.6vw, 1.22rem);
    font-weight: 700;
    letter-spacing: 0;
  }

  h1 {
    max-width: 20ch;
    font-size: clamp(2.35rem, 5vw, 4.4rem);
    font-weight: 800;
    letter-spacing: 0;
    line-height: 1.02;
  }

  /* The looping answer to the headline — synced to the icon via icon-loop */
  .splash-answer {
    display: flex;
    justify-content: center;
    align-items: baseline;
    margin-top: 0.1rem;
    font-size: clamp(1.5rem, 3.4vw, 2.7rem);
    font-weight: 800;
    line-height: 1.1;
    color: #fff;
  }

  .answer-morph {
    position: relative;
    display: inline-block;
    text-align: left;
  }

  .answer-sizer {
    visibility: hidden;
  }

  .answer-word {
    position: absolute;
    left: 0;
    top: 0;
    opacity: 0;
    color: #a9e0ff;
    text-shadow: 0 0 26px rgba(140, 200, 255, 0.5);
    animation: word-pop 20s linear infinite;
  }

  .aw-1 {
    animation-delay: 0s;
  }
  .aw-2 {
    animation-delay: 4s;
  }
  .aw-3 {
    animation-delay: 8s;
  }
  .aw-4 {
    animation-delay: 12s;
  }
  .aw-5 {
    animation-delay: 16s;
  }

  .splash-lede {
    max-width: 35rem;
    color: rgba(255, 255, 255, 0.84);
    font-size: clamp(1rem, 1.35vw, 1.12rem);
    font-weight: 650;
    line-height: 1.35;
  }

  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.8rem;
    margin-top: 0.9rem;
  }

  .hero-primary {
    background: #fff;
    color: #0f3c91;
    box-shadow: 0 18px 50px -28px rgba(0, 0, 0, 0.5);
  }

  .hero-primary:hover {
    border-color: rgba(255, 255, 255, 0.72);
    background: rgba(255, 255, 255, 0.92);
    color: #0f3c91;
    box-shadow: 0 20px 50px -26px rgba(0, 0, 0, 0.58);
  }

  .hero-secondary {
    border-color: rgba(255, 255, 255, 0.25);
    background: rgba(255, 255, 255, 0.1);
    color: #fff;
  }

  .hero-secondary:hover {
    border-color: rgba(255, 255, 255, 0.42);
    background: rgba(255, 255, 255, 0.16);
    color: #fff;
    box-shadow: 0 18px 46px -30px rgba(0, 0, 0, 0.45);
  }

  .sync-teaser {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.7rem;
    max-width: min(100%, 35rem);
    margin-top: 0.25rem;
    padding: 0.62rem 0.82rem;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.1);
    color: rgba(255, 255, 255, 0.82);
    font-size: 0.9rem;
    font-weight: 650;
    line-height: 1.25;
    backdrop-filter: blur(18px) saturate(135%);
    -webkit-backdrop-filter: blur(18px) saturate(135%);
    transition:
      border-color 0.18s ease,
      background 0.18s ease,
      color 0.18s ease,
      transform 0.18s ease;
  }

  .sync-teaser:hover {
    border-color: rgba(255, 255, 255, 0.34);
    background: rgba(255, 255, 255, 0.15);
    color: #fff;
    transform: translateY(-1px);
  }

  .sync-teaser strong {
    color: #ffffff;
    font-weight: 800;
  }

  .device-stack {
    position: relative;
    width: 2.75rem;
    height: 1.72rem;
    flex: none;
  }

  .device-phone,
  .device-watch {
    position: absolute;
    display: block;
    border: 1.5px solid rgba(255, 255, 255, 0.78);
    background: rgba(255, 255, 255, 0.12);
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.08);
  }

  .device-phone {
    left: 0;
    bottom: 0;
    width: 0.98rem;
    height: 1.55rem;
    border-radius: 0.22rem;
  }

  .device-phone::after {
    content: "";
    position: absolute;
    left: 50%;
    bottom: 0.12rem;
    width: 0.18rem;
    height: 0.18rem;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.7);
    transform: translateX(-50%);
  }

  .device-watch {
    right: 0;
    top: 0.32rem;
    width: 1.1rem;
    height: 1.1rem;
    border-radius: 0.36rem;
  }

  .device-watch::before,
  .device-watch::after {
    content: "";
    position: absolute;
    left: 50%;
    width: 0.44rem;
    height: 0.28rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.52);
    transform: translateX(-50%);
  }

  .device-watch::before {
    top: -0.32rem;
  }

  .device-watch::after {
    bottom: -0.32rem;
  }

  .scroll-cue {
    position: absolute;
    z-index: 2;
    right: clamp(1.2rem, 3vw, 2.4rem);
    bottom: clamp(1.2rem, 3vw, 2.4rem);
    display: grid;
    place-items: center;
    width: 3rem;
    height: 3rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.9);
    color: #0f3c91;
  }

  .scroll-cue span {
    width: 0.7rem;
    height: 0.7rem;
    border-right: 2px solid currentColor;
    border-bottom: 2px solid currentColor;
    transform: rotate(45deg) translateY(-2px);
  }

  @media (prefers-reduced-motion: no-preference) {
    .splash-icon-loop,
    .splash-product,
    h1,
    .splash-answer,
    .splash-lede,
    .hero-cta,
    .sync-teaser,
    .scroll-cue {
      opacity: 0;
      animation: splash-enter 0.82s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      will-change: transform, opacity, filter;
    }

    .splash-icon-loop {
      animation-delay: 0.08s;
    }

    .splash-product {
      animation-delay: 0.38s;
    }

    h1 {
      animation-delay: 0.52s;
    }

    .splash-answer {
      animation-delay: 1.04s;
    }

    .splash-lede {
      animation-delay: 1.3s;
    }

    .hero-cta {
      animation-delay: 1.5s;
    }

    .sync-teaser {
      animation-delay: 1.62s;
    }

    .scroll-cue {
      animation-delay: 1.75s;
    }
  }

  @keyframes gradient-teal {
    0%,
    16% {
      opacity: 0;
    }
    20% {
      opacity: 0.92;
    }
    36% {
      opacity: 0.72;
    }
    40% {
      opacity: 0;
    }
    76% {
      opacity: 0;
    }
    80% {
      opacity: 0.48;
    }
    96%,
    100% {
      opacity: 0;
    }
  }

  @keyframes gradient-violet {
    0%,
    36% {
      opacity: 0;
    }
    40% {
      opacity: 0.62;
    }
    56% {
      opacity: 0;
    }
    60% {
      opacity: 0.92;
    }
    76% {
      opacity: 0.56;
    }
    80%,
    100% {
      opacity: 0;
    }
  }

  @keyframes wave-layer-a {
    0% {
      opacity: 0.48;
      transform: translate3d(-8vw, 1vh, 0) rotate(-8deg) scaleX(0.94);
      border-radius: 43% 57% 61% 39% / 58% 42% 58% 42%;
    }
    4% {
      opacity: 0.72;
      transform: translate3d(-1vw, -2vh, 0) rotate(-5deg) scaleX(1.1);
      border-radius: 55% 45% 48% 52% / 45% 55% 45% 55%;
    }
    16% {
      opacity: 0.56;
      transform: translate3d(2vw, -1vh, 0) rotate(-6deg) scaleX(1.02);
      border-radius: 48% 52% 57% 43% / 62% 38% 62% 38%;
    }
    20% {
      opacity: 0.78;
      transform: translate3d(9vw, 2vh, 0) rotate(-12deg) scaleX(1.16);
      border-radius: 58% 42% 46% 54% / 44% 56% 44% 56%;
    }
    36% {
      opacity: 0.54;
      transform: translate3d(4vw, 1vh, 0) rotate(-8deg) scaleX(1.03);
      border-radius: 46% 54% 60% 40% / 60% 40% 60% 40%;
    }
    40% {
      opacity: 0.76;
      transform: translate3d(-7vw, -2vh, 0) rotate(-3deg) scaleX(1.18);
      border-radius: 54% 46% 50% 50% / 40% 60% 40% 60%;
    }
    56% {
      opacity: 0.5;
      transform: translate3d(-2vw, 1vh, 0) rotate(-5deg) scaleX(1.04);
      border-radius: 44% 56% 58% 42% / 62% 38% 62% 38%;
    }
    60% {
      opacity: 0.78;
      transform: translate3d(7vw, -3vh, 0) rotate(-11deg) scaleX(1.2);
      border-radius: 60% 40% 44% 56% / 46% 54% 46% 54%;
    }
    76% {
      opacity: 0.52;
      transform: translate3d(3vw, -1vh, 0) rotate(-7deg) scaleX(1.04);
      border-radius: 48% 52% 56% 44% / 58% 42% 58% 42%;
    }
    80% {
      opacity: 0.74;
      transform: translate3d(-9vw, 2vh, 0) rotate(-2deg) scaleX(1.15);
      border-radius: 42% 58% 60% 40% / 44% 56% 44% 56%;
    }
    96%,
    100% {
      opacity: 0.44;
      transform: translate3d(-8vw, 1vh, 0) rotate(-8deg) scaleX(0.94);
      border-radius: 43% 57% 61% 39% / 58% 42% 58% 42%;
    }
  }

  @keyframes wave-layer-b {
    0% {
      opacity: 0.4;
      transform: translate3d(6vw, -1vh, 0) rotate(7deg) scaleX(1.02);
      border-radius: 55% 45% 48% 52% / 43% 57% 43% 57%;
    }
    4% {
      opacity: 0.58;
      transform: translate3d(-6vw, 2vh, 0) rotate(3deg) scaleX(1.12);
      border-radius: 46% 54% 60% 40% / 58% 42% 58% 42%;
    }
    16% {
      opacity: 0.44;
      transform: translate3d(-2vw, 1vh, 0) rotate(5deg) scaleX(1);
      border-radius: 60% 40% 45% 55% / 40% 60% 40% 60%;
    }
    20% {
      opacity: 0.64;
      transform: translate3d(8vw, -3vh, 0) rotate(10deg) scaleX(1.14);
      border-radius: 48% 52% 60% 40% / 55% 45% 55% 45%;
    }
    36% {
      opacity: 0.42;
      transform: translate3d(3vw, -1vh, 0) rotate(6deg) scaleX(1.02);
      border-radius: 56% 44% 46% 54% / 42% 58% 42% 58%;
    }
    40% {
      opacity: 0.62;
      transform: translate3d(-9vw, 2vh, 0) rotate(2deg) scaleX(1.18);
      border-radius: 44% 56% 62% 38% / 60% 40% 60% 40%;
    }
    56% {
      opacity: 0.44;
      transform: translate3d(-4vw, 0, 0) rotate(4deg) scaleX(1.03);
      border-radius: 60% 40% 46% 54% / 42% 58% 42% 58%;
    }
    60% {
      opacity: 0.64;
      transform: translate3d(7vw, 3vh, 0) rotate(9deg) scaleX(1.16);
      border-radius: 50% 50% 58% 42% / 56% 44% 56% 44%;
    }
    76% {
      opacity: 0.42;
      transform: translate3d(1vw, 1vh, 0) rotate(6deg) scaleX(1.02);
      border-radius: 55% 45% 47% 53% / 44% 56% 44% 56%;
    }
    80% {
      opacity: 0.6;
      transform: translate3d(-8vw, -2vh, 0) rotate(1deg) scaleX(1.14);
      border-radius: 46% 54% 61% 39% / 58% 42% 58% 42%;
    }
    96%,
    100% {
      opacity: 0.4;
      transform: translate3d(6vw, -1vh, 0) rotate(7deg) scaleX(1.02);
      border-radius: 55% 45% 48% 52% / 43% 57% 43% 57%;
    }
  }

  @keyframes wave-layer-c {
    0% {
      opacity: 0.38;
      transform: translate3d(-7vw, 1vh, 0) rotate(-4deg) scaleX(1.04);
      border-radius: 49% 51% 54% 46% / 65% 35% 65% 35%;
    }
    4% {
      opacity: 0.58;
      transform: translate3d(6vw, -3vh, 0) rotate(-9deg) scaleX(1.15);
      border-radius: 56% 44% 47% 53% / 58% 42% 58% 42%;
    }
    16% {
      opacity: 0.42;
      transform: translate3d(3vw, -1vh, 0) rotate(-6deg) scaleX(1.04);
      border-radius: 44% 56% 59% 41% / 62% 38% 62% 38%;
    }
    20% {
      opacity: 0.62;
      transform: translate3d(-7vw, 3vh, 0) rotate(-1deg) scaleX(1.18);
      border-radius: 52% 48% 46% 54% / 44% 56% 44% 56%;
    }
    36% {
      opacity: 0.42;
      transform: translate3d(-2vw, 1vh, 0) rotate(-5deg) scaleX(1.04);
      border-radius: 48% 52% 58% 42% / 64% 36% 64% 36%;
    }
    40% {
      opacity: 0.6;
      transform: translate3d(8vw, -2vh, 0) rotate(-10deg) scaleX(1.14);
      border-radius: 58% 42% 48% 52% / 56% 44% 56% 44%;
    }
    56% {
      opacity: 0.4;
      transform: translate3d(3vw, 0, 0) rotate(-7deg) scaleX(1.02);
      border-radius: 44% 56% 60% 40% / 62% 38% 62% 38%;
    }
    60% {
      opacity: 0.62;
      transform: translate3d(-8vw, 2vh, 0) rotate(-2deg) scaleX(1.17);
      border-radius: 54% 46% 47% 53% / 44% 56% 44% 56%;
    }
    76% {
      opacity: 0.42;
      transform: translate3d(-3vw, 1vh, 0) rotate(-5deg) scaleX(1.03);
      border-radius: 49% 51% 56% 44% / 63% 37% 63% 37%;
    }
    80% {
      opacity: 0.58;
      transform: translate3d(8vw, -2vh, 0) rotate(-9deg) scaleX(1.15);
      border-radius: 56% 44% 50% 50% / 56% 44% 56% 44%;
    }
    96%,
    100% {
      opacity: 0.38;
      transform: translate3d(-7vw, 1vh, 0) rotate(-4deg) scaleX(1.04);
      border-radius: 49% 51% 54% 46% / 65% 35% 65% 35%;
    }
  }

  @keyframes icon-orbit {
    to {
      transform: rotate(1turn);
    }
  }

  @keyframes splash-enter {
    0% {
      opacity: 0;
      filter: blur(8px);
      transform: translateY(18px) scale(0.96);
    }
    65% {
      opacity: 1;
      filter: blur(0);
    }
    100% {
      opacity: 1;
      filter: blur(0);
      transform: translateY(0) scale(1);
    }
  }

  /* Slow logo-to-icon phase loop. The icon rotates gently as it enters so the
     motion feels like a handoff instead of a random spinner. */
  @keyframes icon-loop {
    0% {
      opacity: 0;
