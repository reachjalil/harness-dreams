---
import SiteLayout from "../layouts/SiteLayout.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import Problem from "../components/Problem.astro";
import HowItWorks from "../components/HowItWorks.astro";
import Features from "../components/Features.astro";
import DayInLife from "../components/DayInLife.astro";
import Experiments from "../components/Experiments.astro";
import Privacy from "../components/Privacy.astro";
import FAQ from "../components/FAQ.astro";
import CTA from "../components/CTA.astro";
import Footer from "../components/Footer.astro";

const title = "Harness Dreams — Your Harness Health App";
const description =
  "A health app for your AI coding harnesses. While your harness sleeps, Harness Dreams reviews the day, finds what to fix, and wakes you with a report and experiments to make tomorrow sharper — fewer tokens, less back-and-forth, fewer repeated mistakes. Local-first, macOS.";
---

<SiteLayout title={title} description={description}>
  <Nav />
  <main id="main">
    <Hero />
    <Problem />
    <HowItWorks />
    <Features />
    <DayInLife />
    <Experiments />
    <Privacy />
    <FAQ />
    <CTA />
  </main>
  <Footer />
</SiteLayout>
