---
import CloudSync from "../components/CloudSync.astro";
import CTA from "../components/CTA.astro";
import DailyOptimization from "../components/DailyOptimization.astro";
import Footer from "../components/Footer.astro";
import Hero from "../components/Hero.astro";
import InsightStatements from "../components/InsightStatements.astro";
import ResourceHub from "../components/ResourceHub.astro";
import StoryGallery from "../components/StoryGallery.astro";
import SiteLayout from "../layouts/SiteLayout.astro";

const title = "Harness Health — Your Harness Health App";
const description =
  "A health app for your AI coding harnesses. While your harness rests, Harness Health reviews the day, finds what to fix, and turns repeated patterns into healthier habits. Local-first for macOS, with optional iPhone and Apple Watch connection and a 2-week trial.";
---

<SiteLayout title={title} description={description}>
  <main id="main">
    <Hero />
    <InsightStatements />
    <DailyOptimization />
    <StoryGallery />
    <CloudSync />
    <ResourceHub />
    <CTA />
  </main>
  <Footer />
</SiteLayout>
