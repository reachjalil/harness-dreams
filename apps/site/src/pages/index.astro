---
import CTA from "../components/CTA.astro";
import DailyOptimization from "../components/DailyOptimization.astro";
import Footer from "../components/Footer.astro";
import Hero from "../components/Hero.astro";
import InsightStatements from "../components/InsightStatements.astro";
import ResourceHub from "../components/ResourceHub.astro";
import StoryGallery from "../components/StoryGallery.astro";
import SiteLayout from "../layouts/SiteLayout.astro";

const title = "Harness Dreams — Your Harness Health App";
const description =
  "A health app for your AI coding harnesses. While your harness sleeps, Harness Dreams reviews the day, finds what to fix, and wakes you with a report of suggested improvements to make tomorrow sharper — fewer tokens, less back-and-forth, fewer repeated mistakes. Local-first, macOS.";
---

<SiteLayout title={title} description={description}>
  <main id="main">
    <Hero />
    <InsightStatements />
    <DailyOptimization />
    <StoryGallery />
    <ResourceHub />
    <CTA />
  </main>
  <Footer />
</SiteLayout>
