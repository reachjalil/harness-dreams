---
import Footer from "../components/Footer.astro";
import Nav from "../components/Nav.astro";
import SiteLayout from "../layouts/SiteLayout.astro";

const title = "Download for macOS - Harness Dreams";
const description =
  "Set up Harness Dreams on macOS. The signed app is being prepared with Apple notarization; until then, clone the repo and run the desktop app locally.";
const repoUrl = "https://github.com/reachjalil/harness-dreams";
---

<SiteLayout title={title} description={description}>
  <Nav />
  <main id="main">
    <section class="setup-hero">
      <div class="setup-waves" aria-hidden="true">
        <span></span>
        <span></span>
      </div>

      <div class="container setup-hero-grid">
        <div class="setup-intro">
          <span class="eyebrow">macOS developer preview</span>
          <h1>Set up Harness Dreams locally.</h1>
          <p class="lead">
            The signed macOS download is in progress. For now, clone the repo,
            install dependencies, and launch the Electron app from source.
          </p>
          <div class="start-actions">
            <a class="btn btn-primary setup-primary" href={repoUrl} target="_blank" rel="noreferrer noopener">
              View GitHub
            </a>
            <a class="btn setup-secondary" href="#status">Signing status</a>
          </div>
          <p class="setup-note">
            We are preparing Developer ID signing and Apple notarization so the
            first normal download opens cleanly through macOS Gatekeeper.
          </p>
        </div>

        <aside class="setup-panel" aria-label="Local setup steps">
          <div class="panel-head">
            <span class="mono">Run from source</span>
            <span class="download-pill">Download coming soon</span>
          </div>

          <div class="prereqs" aria-label="Requirements">
            <span>macOS</span>
            <span>Node 22.12+</span>
            <span>Corepack</span>
          </div>

          <ol class="command-steps">
            <li>
              <span class="step-index mono">01</span>
              <div>
                <h2>Clone the repository</h2>
                <pre><code>git clone https://github.com/reachjalil/harness-dreams.git
cd harness-dreams</code></pre>
              </div>
            </li>
            <li>
              <span class="step-index mono">02</span>
              <div>
                <h2>Install dependencies</h2>
                <pre><code>corepack enable
pnpm install</code></pre>
              </div>
            </li>
            <li>
              <span class="step-index mono">03</span>
              <div>
                <h2>Launch the app</h2>
                <pre><code>pnpm --filter @harness-dreams/desktop start</code></pre>
              </div>
            </li>
          </ol>
        </aside>
      </div>
    </section>

    <section class="section status-section" id="status">
      <div class="container status-grid">
        <article class="info-block reveal">
          <span class="mono">Signed app</span>
          <h2>We are getting the app ready for Apple signing.</h2>
          <p>
            Harness Dreams is a local-first menu-bar app, so the install path
            should feel standard: signed with Developer ID, notarized by Apple,
            and accepted by Gatekeeper.
          </p>
        </article>

        <article class="info-block reveal" data-delay="1">
          <span class="mono">Current path</span>
          <h2>The source setup is the preview path.</h2>
          <p>
            Use macOS, Node.js 22.12 or newer, and Corepack. The commands above
            start the desktop app in development mode while the signed download
            and updater are being finished.
          </p>
        </article>
      </div>
    </section>
  </main>
  <Footer />
</SiteLayout>

<style>
  .setup-hero {
    position: relative;
    min-height: 100svh;
    display: grid;
    align-items: center;
    overflow: hidden;
    isolation: isolate;
    padding-block: clamp(7rem, 10vw, 8.5rem) clamp(3rem, 6vw, 4.5rem);
    background:
      linear-gradient(180deg, rgba(0, 0, 0, 0.04), transparent 38%),
      linear-gradient(150deg, #084c9a 0%, #0c82c2 100%);
    color: #fff;
  }

  .setup-hero::before,
  .setup-hero::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .setup-hero::before {
    background: linear-gradient(150deg, #075f57 0%, #169f91 100%);
    opacity: 0.34;
  }

  .setup-hero::after {
    background: radial-gradient(circle at 76% 24%, rgba(255, 255, 255, 0.18), transparent 34%);
    opacity: 0.8;
  }

  .setup-waves {
    position: absolute;
    inset: 0;
    z-index: 1;
    overflow: hidden;
    pointer-events: none;
  }

  .setup-waves span {
    position: absolute;
    left: -18vw;
    width: 136vw;
    height: clamp(15rem, 31vw, 28rem);
    border-radius: 999px;
    filter: blur(7px);
    mix-blend-mode: screen;
    background:
      radial-gradient(ellipse at 22% 48%, rgba(255, 255, 255, 0.24), transparent 38%),
      linear-gradient(92deg, transparent, rgba(255, 255, 255, 0.16), transparent);
  }

  .setup-waves span:first-child {
    top: 12vh;
    transform: rotate(-8deg);
  }

  .setup-waves span:last-child {
    top: 48vh;
    opacity: 0.7;
    transform: rotate(-12deg);
  }

  .setup-hero-grid {
    position: relative;
    z-index: 2;
    display: grid;
    gap: clamp(2rem, 6vw, 4rem);
    align-items: center;
  }

  .setup-intro {
    display: grid;
    gap: 1rem;
  }

  .setup-intro .eyebrow {
    color: #a9e0ff;
  }

  .setup-intro h1 {
    max-width: 12ch;
    color: #fff;
    font-family: var(--font-display);
    font-size: clamp(2.7rem, 5.4vw, 4.75rem);
    font-weight: 800;
    letter-spacing: 0;
    line-height: 1;
  }

  .setup-intro .lead {
    max-width: 34rem;
    color: rgba(255, 255, 255, 0.82);
    font-size: clamp(1.02rem, 1.45vw, 1.18rem);
    font-weight: 650;
    line-height: 1.38;
  }

  .start-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 0.2rem;
  }

  .setup-primary {
    background: #fff;
    color: #0f3c91;
    box-shadow: 0 18px 50px -28px rgba(0, 0, 0, 0.5);
  }

  .setup-primary:hover {
    border-color: rgba(255, 255, 255, 0.72);
    background: rgba(255, 255, 255, 0.92);
    color: #0f3c91;
  }

  .setup-secondary {
    border-color: rgba(255, 255, 255, 0.25);
    background: rgba(255, 255, 255, 0.1);
    color: #fff;
  }

  .setup-secondary:hover {
    border-color: rgba(255, 255, 255, 0.42);
    background: rgba(255, 255, 255, 0.16);
    color: #fff;
  }

  .setup-note {
    max-width: 34rem;
    color: rgba(255, 255, 255, 0.68);
    font-size: 0.98rem;
    font-weight: 600;
    line-height: 1.45;
  }

  .setup-panel {
    border: 1px solid rgba(255, 255, 255, 0.24);
    border-radius: 28px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.16), rgba(255, 255, 255, 0.07)),
      rgba(255, 255, 255, 0.08);
    box-shadow: 0 26px 80px -48px rgba(0, 0, 0, 0.58);
    backdrop-filter: blur(24px) saturate(130%);
    -webkit-backdrop-filter: blur(24px) saturate(130%);
    padding: clamp(1rem, 2.3vw, 1.45rem);
  }

  .panel-head {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.85rem;
  }

  .download-pill {
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 999px;
    padding: 0.38rem 0.72rem;
    background: rgba(255, 255, 255, 0.1);
    color: #fff;
    font-weight: 750;
    font-size: 0.82rem;
  }

  .prereqs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .prereqs span {
    border: 1px solid rgba(255, 255, 255, 0.13);
    border-radius: 999px;
    padding: 0.32rem 0.58rem;
    background: rgba(255, 255, 255, 0.08);
    color: rgba(255, 255, 255, 0.76);
    font-size: 0.76rem;
    font-weight: 750;
  }

  .command-steps {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.7rem;
  }

  .command-steps li {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 0.78rem;
    align-items: start;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    padding-top: 0.7rem;
  }

  .command-steps li:first-child {
    border-top: 0;
    padding-top: 0;
  }

  .step-index {
    color: #a9e0ff;
    padding-top: 0.25rem;
  }

  .command-steps h2 {
    margin: 0 0 0.38rem;
    color: #fff;
    font-family: var(--font-display);
    font-size: clamp(0.98rem, 1.65vw, 1.12rem);
    font-weight: 800;
    line-height: 1.1;
  }

  pre {
    margin: 0;
    overflow-x: auto;
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.13);
    background: rgba(4, 22, 42, 0.58);
    color: #eef7ff;
    padding: 0.68rem 0.8rem;
  }

  code {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    line-height: 1.58;
  }

  .status-section {
    background:
      linear-gradient(180deg, #ffffff, rgba(167, 218, 211, 0.12)),
      var(--bg);
  }

  .status-grid {
    display: grid;
    gap: 1rem;
  }

  .info-block {
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    background: rgba(255, 255, 255, 0.82);
    box-shadow: var(--shadow-soft);
    padding: clamp(1.3rem, 3vw, 1.8rem);
  }

  .info-block h2 {
    margin-top: 0.65rem;
    font-family: var(--font-display);
    font-size: clamp(1.35rem, 3vw, 1.85rem);
    font-weight: 800;
    line-height: 1.12;
  }

  .info-block p {
    color: var(--muted);
    margin-top: 0.75rem;
  }

  @media (min-width: 900px) {
    .setup-hero-grid {
      grid-template-columns: minmax(0, 0.82fr) minmax(26rem, 1fr);
    }

    .status-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 700px) {
    .setup-hero {
      min-height: auto;
    }

    .setup-intro h1 {
      max-width: 11ch;
    }
  }
</style>
