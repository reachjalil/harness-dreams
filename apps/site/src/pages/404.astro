---
import SiteLayout from "../layouts/SiteLayout.astro";
---

<SiteLayout
  title="Page not found | Harness Dreams"
  description="That page does not exist."
>
  <main class="wrap" id="main">
    <div class="card">
      <span class="pill">
        <span class="mono">404</span>
      </span>
      <h1>Lost in a dream.</h1>
      <p class="sub">That page does not exist.</p>
      <div class="links">
        <a class="btn" href="/">Back to home <span aria-hidden="true">&rarr;</span></a>
      </div>
    </div>
  </main>
</SiteLayout>
