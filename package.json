{
  "name": "harness-health",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "license": "MIT",
  "packageManager": "pnpm@10.30.2",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "build": "turbo run build",
    "check": "turbo run check",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "biome check --assist-enabled=false .",
    "lint:fix": "biome format --write . && biome lint --write .",
    "format": "biome format --write .",
    "imports": "biome check --write --assist-enabled=true --only=assist/source/organizeImports .",
    "harness:validate": "npx harnessc validate",
    "harness:preview": "npx harnessc activate",
    "harness:activate": "npx harnessc activate --yes",
    "harness-health:scan": "tsx scripts/harness-health-scan.ts",
    "types": "pnpm -r --if-present run types",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "turbo run build && changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@changesets/cli": "^2.31.0",
    "turbo": "^2.9.6",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "workerd"
    ]
  }
}
